<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AddNewEquipment">

    <!-- Top Nav -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/topNavBar2"
        android:name="com.example.nasa_taskmaster.TopNavBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:layout="@layout/fragment_top_nav_bar" />

    <!-- Bottom Nav -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/navigationBar2"
        android:name="com.example.nasa_taskmaster.Navigation_Bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:layout="@layout/fragment_navigation__bar" />

    <!-- Scrollable content between navbars -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topNavBar2"
        app:layout_constraintBottom_toTopOf="@id/navigationBar2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- Equipment Name Label -->
            <TextView
                android:id="@+id/taskNameLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Equipment Name"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <!-- Equipment Name Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/equipmentNameInputBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/taskName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter equipment name"
                    tools:ignore="TouchTargetSizeCheck" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="2dp"
                android:background="?attr/colorOutline"
                android:alpha="0.2" />

            <!-- Equipment Year Label -->
            <TextView
                android:id="@+id/equipmentYearInputLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Equipment Year"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginTop="12dp" />

            <!-- Equipment Year Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/equipmentYearInputBoxtextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/equipmentYearInputBoxBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:hint="Enter year"
                    tools:ignore="TouchTargetSizeCheck" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="2dp"
                android:background="?attr/colorOutline"
                android:alpha="0.2" />

            <!-- Equipment Status Label -->
            <TextView
                android:id="@+id/equipmentStatusLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Equipment Status"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginTop="12dp" />

            <!-- Equipment Status Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/equipmentStatusInputBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/taskDescript"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter status"
                    tools:ignore="TouchTargetSizeCheck" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="2dp"
                android:background="?attr/colorOutline"
                android:alpha="0.2" />

            <!-- Equipment Description Label -->
            <TextView
                android:id="@+id/equipmentDescriptionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Equipment Description"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginTop="12dp" />

            <!-- Equipment Description Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/equipmentDescriptionInputBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/equipmentDescriptionInputBoxBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter description"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:gravity="top"
                    tools:ignore="TouchTargetSizeCheck" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="2dp"
                android:background="?attr/colorOutline"
                android:alpha="0.2" />

            <!-- Location Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginTop="12dp" />

            <!-- Location Spinner -->
            <Spinner
                android:id="@+id/addLocationSpinner2"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp" />

            <!-- Map -->
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/mapFragmentEquipmentDetails2"
                android:name="com.example.nasa_taskmaster.MainMapFragment"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="12dp"
                tools:layout="@layout/fragment_support_map" />

            <!-- Add Equipment Button -->
            <Button
                android:id="@+id/addTaskBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add New Equipment"
                android:textSize="16sp"
                android:layout_marginTop="16dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>