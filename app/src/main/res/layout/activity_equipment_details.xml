<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".EquipmentDetails">

    <!-- Top Nav -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/topNavBar3"
        android:name="com.example.nasa_taskmaster.TopNavBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:layout="@layout/fragment_top_nav_bar" />

    <!-- Bottom Nav -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/navigationBar3"
        android:name="com.example.nasa_taskmaster.Navigation_Bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:layout="@layout/fragment_navigation__bar" />

    <!-- Scrollable content between navbars -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topNavBar3"
        app:layout_constraintBottom_toTopOf="@id/navigationBar3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- Equipment Name Label -->
            <TextView
                android:id="@+id/equipmentNameLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Equipment Name"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <!-- Equipment Name -->
            <TextView
                android:id="@+id/equipmentNameView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                tools:text="Hubble Space Telescope" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="2dp"
                android:background="?attr/colorOutline"
                android:alpha="0.2" />

            <!-- Equipment Year Label -->
            <TextView
                android:id="@+id/equipmentYearLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Equipment Year"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginTop="12dp" />

            <!-- Equipment Year -->
            <TextView
                android:id="@+id/equipmentYearView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:layout_marginTop="4dp"
                tools:text="2003" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="2dp"
                android:background="?attr/colorOutline"
                android:alpha="0.2" />

            <!-- Equipment Status Label -->
            <TextView
                android:id="@+id/equipmentStatusLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Equipment Status"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginTop="12dp" />

            <!-- Equipment Status -->
            <TextView
                android:id="@+id/equipmentStatusView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:layout_marginTop="4dp"
                tools:text="Operational" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="2dp"
                android:background="?attr/colorOutline"
                android:alpha="0.2" />

            <!-- Equipment Description Label -->
            <TextView
                android:id="@+id/equipmentDescriptionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Equipment Description"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginTop="12dp" />

            <!-- Equipment Description -->
            <TextView
                android:id="@+id/equipmentDetailsEquipmentDescriptionView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="4dp"
                tools:text="Used for deep-space imaging and orbital diagnostics." />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="2dp"
                android:background="?attr/colorOutline"
                android:alpha="0.2" />

            <!-- Location Label -->
            <TextView
                android:id="@+id/equipmentLocationLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginTop="12dp" />

            <!-- Location Value -->
            <TextView
                android:id="@+id/equipmentDetailsEquipmentLocationView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:layout_marginTop="4dp"
                tools:text="Low Earth Orbit" />

            <!-- Map -->
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/mapFragmentEquipmentDetails"
                android:name="com.example.nasa_taskmaster.ShowLocationMapFragment"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="12dp"
                tools:layout="@layout/fragment_support_map" />

            <!-- Edit Details Button -->
            <Button
                android:id="@+id/saveDetailsButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Edit Details"
                android:textSize="16sp"
                android:layout_marginTop="16dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>