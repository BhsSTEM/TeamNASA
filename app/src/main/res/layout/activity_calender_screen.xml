<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:accessibilityLiveRegion="assertive"
    android:background="#EDEDED"
    android:backgroundTint="#FFFEFE"
    android:backgroundTintMode="add"
    android:focusable="auto"
    android:textAlignment="center"
    tools:context=".CalenderScreen">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/navigationBar6"
        android:name="com.example.nasa_taskmaster.Navigation_Bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout="@layout/fragment_navigation__bar" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/topNavBar8"
        android:name="com.example.nasa_taskmaster.TopNavBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout="@layout/fragment_top_nav_bar" />

    <CalendarView
        android:id="@+id/calendarView"
        style="@android:style/Widget.DeviceDefault.Light.CalendarView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="64dp"
        android:layout_marginHorizontal="64dp"
        android:layout_marginVertical="128dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="64dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="128dp"
        android:background="#FFFFFF"
        android:contextClickable="true"
        android:dateTextAppearance="@style/TextAppearance.AppCompat.Large"
        android:focusable="auto"
        android:focusableInTouchMode="true"
        android:focusedMonthDateColor="#FFFFFF"
        android:forceHasOverlappingRendering="false"
        android:hapticFeedbackEnabled="true"
        android:layoutMode="clipBounds"
        android:padding="0dp"
        android:paddingHorizontal="64dp"
        android:paddingVertical="64dp"
        android:selectedWeekBackgroundColor="@color/black"
        android:showWeekNumber="false"
        android:weekDayTextAppearance="@style/TextAppearance.AppCompat.Large"
        android:weekNumberColor="#FFFFFF"
        android:weekSeparatorLineColor="#1B0A0A"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5"
        app:layout_marginBaseline="64dp"
        app:layout_wrapBehaviorInParent="included" />

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:adjustViewBounds="false"
        android:cropToPadding="false"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="@+id/calendarView"
        app:layout_constraintEnd_toEndOf="@+id/calendarView"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/calendarView"
        app:layout_constraintTop_toTopOf="@+id/calendarView"
        app:layout_constraintVertical_bias="0.0"
        app:srcCompat="@drawable/ic_launcher_background"
        tools:visibility="invisible" />

    <Button
        android:id="@+id/backBtnCalendar"
        style="@style/Widget.AppCompat.Button.Borderless.Colored"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:cursorVisible="true"
        app:iconTint="#FBFBFB"
        app:iconTintMode="src_over"
        app:layout_constraintBottom_toBottomOf="@+id/calendarView"
        app:layout_constraintEnd_toEndOf="@+id/calendarView"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="@+id/calendarView"
        app:layout_constraintTop_toTopOf="@+id/calendarView"
        app:layout_constraintVertical_bias="0.025"
        app:strokeColor="#141313" />

    <Button
        android:id="@+id/forwardBtnCalendar2"
        style="@style/Widget.AppCompat.Button.Borderless.Colored"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTintMode="src_atop"
        android:clickable="true"
        android:contextClickable="true"
        android:cursorVisible="true"
        android:visibility="visible"
        app:iconTint="@color/white"
        app:iconTintMode="src_atop"
        app:layout_constraintBottom_toBottomOf="@+id/calendarView"
        app:layout_constraintEnd_toEndOf="@+id/calendarView"
        app:layout_constraintHorizontal_bias="1"
        app:layout_constraintStart_toStartOf="@+id/calendarView"
        app:layout_constraintTop_toTopOf="@+id/calendarView"
        app:layout_constraintVertical_bias="0.025"
        app:strokeColor="@color/white"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>